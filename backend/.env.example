NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DIRECT_URL=
JWT_ACCESS_SECRET=replace-with-a-random-string-of-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-different-random-string-of-at-least-32-characters
CORS_ORIGIN=http://localhost:5173
REDIS_URL=redis://localhost:6379
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_MS=60000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/calendar/oauth/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=
# Local: use your SMTP provider or a test inbox. Production/Render: Brevo SMTP relay.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
LOG_LEVEL=debug
